const BASE_URL = "http://localhost:5000";

/* ================= SUBSCRIBE ================= */
export const subscribe = async (creatorId, token) => {
  const res = await fetch(`${BASE_URL}/subscriptions/${creatorId}`, {
    method: "POST",
    headers: {
      Authorization: "Bearer " + token,
    },
  });

  return res.json();
};

/* ================= UNSUBSCRIBE ================= */
export const unsubscribe = async (creatorId, token) => {
  const res = await fetch(`${BASE_URL}/subscriptions/${creatorId}`, {
    method: "DELETE",
    headers: {
      Authorization: "Bearer " + token,
    },
  });

  return res.json();
};

